@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix mds: <https://cwrusdle.bitbucket.io/mds/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@base <http://www.w3.org/2002/07/owl#> .

[ rdf:type owl:Ontology
 ] .

#################################################################
#    Annotation properties
#################################################################

###  http://www.w3.org/2004/02/skos/core#definition
skos:definition rdf:type owl:AnnotationProperty .


###  http://www.w3.org/2004/02/skos/core#exactMatch
skos:exactMatch rdf:type owl:AnnotationProperty .


###  https://cwrusdle.bitbucket.io/mds/isTemplateHead
mds:isTemplateHead rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000196
obo:BFO_0000196 rdf:type owl:ObjectProperty ;
                rdfs:domain [ owl:intersectionOf ( obo:BFO_0000004
                                                   [ rdf:type owl:Class ;
                                                     owl:complementOf obo:BFO_0000006
                                                   ]
                                                 ) ;
                              rdf:type owl:Class
                            ] ;
                rdfs:range obo:BFO_0000020 .


###  https://www.commoncoreontologies.org/ont00001879
cco:ont00001879 rdf:type owl:ObjectProperty ;
                rdfs:range cco:ont00000686 .


#################################################################
#    Classes
#################################################################

###  http://purl.obolibrary.org/obo/BFO_0000004
obo:BFO_0000004 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000006
obo:BFO_0000006 rdf:type owl:Class .


###  http://purl.obolibrary.org/obo/BFO_0000020
obo:BFO_0000020 rdf:type owl:Class .


###  https://cwrusdle.bitbucket.io/mds/BeamlineOptic
mds:BeamlineOptic rdf:type owl:Class ;
                  rdfs:subClassOf cco:ont00000995 .


###  https://cwrusdle.bitbucket.io/mds/ComponentBrand
mds:ComponentBrand rdf:type owl:Class ;
                   rdfs:subClassOf mds:Name .


###  https://cwrusdle.bitbucket.io/mds/Name
mds:Name rdf:type owl:Class .


###  https://cwrusdle.bitbucket.io/mds/SlitOrientation
mds:SlitOrientation rdf:type owl:Class ;
                    rdfs:subClassOf cco:ont00000119 .


###  https://cwrusdle.bitbucket.io/mds/Split
mds:Split rdf:type owl:Class ;
          owl:equivalentClass [ rdf:type owl:Restriction ;
                                owl:onProperty obo:BFO_0000196 ;
                                owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass mds:SlitOrientation
                              ] ;
          rdfs:subClassOf mds:BeamlineOptic ;
          rdfs:label "Split" ;
          skos:definition "A subset of the dataset used in training a neural network with a specialized role in the training process, represented as a decimal fraction of the dataset."@en ;
          skos:exactMatch mds:Split .


###  https://www.commoncoreontologies.org/ont00000119
cco:ont00000119 rdf:type owl:Class ;
                rdfs:label "Spatial Orientation"@en ;
                skos:definition "A Relational Quality that is the angle of Rotation of an Object relative to one or more Plane of Reference or Axis of Rotation."@en ;
                skos:exactMatch cco:ont00000119 .


###  https://www.commoncoreontologies.org/ont00000686
cco:ont00000686 rdf:type owl:Class .


###  https://www.commoncoreontologies.org/ont00000995
cco:ont00000995 rdf:type owl:Class ;
                rdfs:label "Material Artifact"@en ;
                skos:definition "A Material Entity that was designed by some Agent to realize a certain Function."@en ;
                skos:exactMatch cco:ont00000995 .


#################################################################
#    Individuals
#################################################################

###  https://cwrusdle.bitbucket.io/mds/Horizontal
mds:Horizontal rdf:type owl:NamedIndividual ,
                        mds:SlitOrientation .


###  https://cwrusdle.bitbucket.io/mds/JJ
mds:JJ rdf:type owl:NamedIndividual ,
                mds:ComponentBrand .


###  https://cwrusdle.bitbucket.io/mds/JJUSSlit
mds:JJUSSlit rdf:type owl:NamedIndividual ,
                      mds:Split ;
             obo:BFO_0000196 mds:Horizontal ;
             mds:isTemplateHead mds:BeamlineSlitTemplate ;
             cco:ont00001879 mds:JJ .


###  https://cwrusdle.bitbucket.io/mds/Kozhu
mds:Kozhu rdf:type owl:NamedIndividual ,
                   mds:ComponentBrand .


###  https://cwrusdle.bitbucket.io/mds/KozhuDSSlit
mds:KozhuDSSlit rdf:type owl:NamedIndividual ,
                         mds:Split ;
                obo:BFO_0000196 mds:Vertical ;
                mds:isTemplateHead mds:BeamlineSlitTemplate ;
                cco:ont00001879 mds:Kozhu .


###  https://cwrusdle.bitbucket.io/mds/Vertical
mds:Vertical rdf:type owl:NamedIndividual ,
                      mds:SlitOrientation .


#################################################################
#    Annotations
#################################################################

obo:BFO_0000196 rdfs:label "bearer of"@en ;
                skos:definition "b bearer of c =Def c inheres in b"@en ;
                skos:exactMatch obo:BFO_0000196 .


cco:ont00001879 rdfs:label "designated by"@en ;
                skos:definition "x designated_by y iff y is an instance of Information Content Entity and x is an instance of Entity, such that given some context, y uniquely distinguishes x from other entities."@en ;
                skos:exactMatch cco:ont00001879 .


