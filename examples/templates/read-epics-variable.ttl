@prefix cco: <https://www.commoncoreontologies.org/> .
@prefix mds: <https://cwrusdle.bitbucket.io/mds/> .
@prefix obo: <http://purl.obolibrary.org/obo/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

mds:EPICSVariable a owl:NamedIndividual,
        mds:EPICSPVVariable ;
    obo:BFO_0000084 mds:LabelOfEPICSVariable ;
    mds:isTemplateHead mds:ReadEPICSVariable .

obo:BFO_0000084 a owl:ObjectProperty ;
    rdfs:label "generically depends on"@en ;
    rdfs:domain obo:BFO_0000031 ;
    rdfs:range [ ] ;
    skos:exactMatch obo:BFO_0000084 .

mds:EPICSPVVariable a owl:Class ;
    rdfs:subClassOf cco:ont00000077 .

mds:LabelOfEPICSVariable a owl:NamedIndividual,
        cco:ont00000253 ;
    cco:ont00001765 "Value"^^xsd:string .

cco:ont00001765 a owl:DatatypeProperty ;
    rdfs:label "has text value"@en ;
    rdfs:domain cco:ont00000253 ;
    skos:exactMatch cco:ont00001765 .

cco:ont00000077 a owl:Class ;
    rdfs:label "Code Identifier"@en ;
    skos:exactMatch cco:ont00000077 .

cco:ont00000253 a owl:Class ;
    rdfs:label "Information Bearing Entity"@en ;
    skos:exactMatch cco:ont00000253 .

